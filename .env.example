# EggSight frontend environment variables
# Copy this file to `.env` and fill in the values. All vars are exposed to the
# browser (Vite only bundles vars prefixed with VITE_), so only use public keys.

# Supabase project — Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# EggSight forecast API base URL (FastAPI service on Render)
VITE_EGGSIGHT_API_URL=https://api.cefpl.in
